<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <UseXUnit>false</UseXUnit>
    <OutputType>Exe</OutputType>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <TestingPlatformCaptureOutput>false</TestingPlatformCaptureOutput>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Finbuckle.MultiTenant" Version="8.1.12" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Finbuckle.MultiTenant" Version="9.4.7" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Finbuckle.MultiTenant" Version="10.0.4" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Testcontainers" Version="3.5.0" />
    <PackageReference Include="Testcontainers.MongoDb" Version="3.5.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" Version="0.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Deveel.Repository.MongoFramework.MultiTenant\Deveel.Repository.MongoFramework.MultiTenant.csproj" />
    <ProjectReference Include="..\..\src\Deveel.Repository.MongoFramework\Deveel.Repository.MongoFramework.csproj" />
    <ProjectReference Include="..\Deveel.Repository.Testing.TUnit\Deveel.Repository.Testing.TUnit.csproj" />
  </ItemGroup>

</Project>

